/**
 * Calculates the Euclidean distance between two nodes on a screen, considering their screen sizes and positions.
 * This function ensures robust input validation and error handling to guarantee that both nodes are correctly structured
 * and contain the necessary properties for distance calculation.
 * 
 * @param node1 The first node object, which must include 'screenSize' and 'nodePagePosition' properties.
 *              'screenSize' should have a 'screen' object with 'width' and 'height' as numbers.
 *              'nodePagePosition' should have 'left' and 'top' as numbers.
 * @param node2 The second node object, similar in structure to node1, used for comparison.
 * 
 * @returns The calculated distance as a number. If the nodes are missing required properties or if any property is of incorrect type,
 *          the function will throw an error with a descriptive message.
 * 
 * @throws {Error} Throws an error if either node is undefined, if required properties are missing, or if properties are of incorrect type.
 *         Errors include but are not limited to:
 *         - "Both nodes must be provided." if either node is undefined.
 *         - "Both nodes must have a 'screenSize' property." if either node lacks a 'screenSize'.
 *         - "Both nodes must have a 'nodePagePosition' property." if either node lacks a 'nodePagePosition'.
 *         - "Screen width must be a number." if the screen width is not a number.
 *         - "Screen height must be a number." if the screen height is not a number.
 *         - "Node page position left must be a number." if the node page position left is not a number.
 *         - "Node page position top must be a number." if the node page position top is not a number.
 */
export const getDistance = (node1: any, node2: any): number => {
  try {
    // Validate input nodes
    if (!node1 || !node2) {
      throw new Error("Both nodes must be provided.");
    }

    // Validate existence of necessary properties
    if (!node1.screenSize || !node2.screenSize) {
      throw new Error("Both nodes must have a 'screenSize' property.");
    }
    if (!node1.nodePagePosition || !node2.nodePagePosition) {
      throw new Error("Both nodes must have a 'nodePagePosition' property.");
    }

    // Validate types of necessary properties
    if (typeof node1.screenSize.screen.width !== 'number' || typeof node2.screenSize.screen.width !== 'number') {
      throw new Error("Screen width must be a number.");
    }
    if (typeof node1.screenSize.screen.height !== 'number' || typeof node2.screenSize.screen.height !== 'number') {
      throw new Error("Screen height must be a number.");
    }
    if (typeof node1.nodePagePosition.left !== 'number' || typeof node2.nodePagePosition.left !== 'number') {
      throw new Error("Node page position left must be a number.");
    }
    if (typeof node1.nodePagePosition.top !== 'number' || typeof node2.nodePagePosition.top !== 'number') {
      throw new Error("Node page position top must be a number.");
    }

    let dist;
    let x, y;
    // Calculate distance based on screen size
    if (node1.screenSize.screen.width > node2.screenSize.screen.width) {
      x = node1.nodePagePosition.left - (node2.nodePagePosition.left * (node2.screenSize.screen.width / node1.screenSize.screen.width));
      y = node1.nodePagePosition.top - (node2.nodePagePosition.top * (node2.screenSize.screen.height / node1.screenSize.screen.height));
    } else if (node1.screenSize.screen.width < node2.screenSize.screen.width) {
      x = (node1.nodePagePosition.left * (node2.screenSize.screen.width / node1.screenSize.screen.width)) - node2.nodePagePosition.left;
      y = (node1.nodePagePosition.top * (node2.screenSize.screen.height / node1.screenSize.screen.height)) - node2.nodePagePosition.top;
    } else {
      x = node1.nodePagePosition.left - node2.nodePagePosition.left;
      y = node1.nodePagePosition.top - node2.nodePagePosition.top;
    }
    dist = Math.sqrt(Math.pow(x, 2) + Math.pow(y, 2));

    return Math.abs(dist);
  } catch (error) {
    console.error('Failed to calculate distance:', error);
    throw error;
  }
};
