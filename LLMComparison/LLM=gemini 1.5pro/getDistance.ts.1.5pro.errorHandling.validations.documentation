/**
 * Calculates the distance between two nodes, with robust input validations and error handling.
 *
 * This function determines the distance between two provided nodes, considering screen size if available. 
 * It prioritizes using screen size for a more accurate calculation when the `screenSize` property is present 
 * and valid on both nodes. If `screenSize` is missing or invalid (e.g., width or height is zero or negative), 
 * it gracefully falls back to using `nodePosition` for calculation.
 *
 * The function incorporates comprehensive input validations to ensure data integrity and prevent unexpected errors:
 *   - **Node Existence:** Checks if both `node1` and `node2` are defined.
 *   - **Property Existence:** Verifies the presence of required properties like `nodePagePosition`, `left`, and `top` on both nodes.
 *   - **Screen Size Consistency:** Ensures that `screenSize` is either present on both nodes or absent on both.
 *   - **Screen Size Property Existence:** If `screenSize` is provided, it validates the existence of `screen`, `width`, and `height` properties.
 *   - **Valid Screen Dimensions:** Checks if `screenSize` values are valid, ensuring width and height are greater than zero.
 *
 * In case any validation fails, it logs a descriptive error message to the console and returns 0. 
 * Additionally, the function is wrapped in a try-catch block to handle any potential runtime errors during calculation. 
 * If an exception occurs, it logs an error message and returns 0, preventing the application from crashing.
 *
 * @param node1 - The first node object. It should contain `nodePagePosition` (with `left` and `top`), 
 *                 optional `screenSize` (with `screen`, `width`, and `height`), and optional `nodePosition`.
 * @param node2 - The second node object. It should contain `nodePagePosition` (with `left` and `top`), 
 *                 optional `screenSize` (with `screen`, `width`, and `height`), and optional `nodePosition`.
 * @returns The calculated distance between the two nodes as a number. Returns 0 if an error occurs during calculation 
 *          or if the input validation fails.
 */
export const getDistance = (node1: any, node2: any) => {
  let dist;
  try {
    // Input validations
    if (!node1 || !node2) {
      console.error('Error: Invalid input nodes.');
      return 0; 
    }

    if (
      !node1.hasOwnProperty('nodePagePosition') ||
      !node2.hasOwnProperty('nodePagePosition') ||
      !node1.nodePagePosition.hasOwnProperty('left') ||
      !node1.nodePagePosition.hasOwnProperty('top') ||
      !node2.nodePagePosition.hasOwnProperty('left') ||
      !node2.nodePagePosition.hasOwnProperty('top')
    ) {
      console.error('Error: Missing required node position properties.');
      return 0;
    }

    // Optional screenSize validation - only check if screenSize exists on both nodes
    if (node1.hasOwnProperty('screenSize') && node2.hasOwnProperty('screenSize')) { 
      if (
        !node1.screenSize.hasOwnProperty('screen') ||
        !node2.screenSize.hasOwnProperty('screen') ||
        !node1.screenSize.screen?.hasOwnProperty('width') ||
        !node1.screenSize.screen?.hasOwnProperty('height') ||
        !node2.screenSize.screen?.hasOwnProperty('width') ||
        !node2.screenSize.screen?.hasOwnProperty('height')
      ) {
        console.error('Error: Missing required screen size properties.');
        return 0;
      }

      // If screen size is available and any of the width or height is 0 or negative, then fall back to using nodePosition
      if (
        node1.screenSize.screen?.width <= 0 ||
        node1.screenSize.screen?.height <= 0 ||
        node2.screenSize.screen?.width <= 0 ||
        node2.screenSize.screen?.height <= 0
      ) {
        console.warn('Warning: Invalid screen size detected. Using nodePosition instead.');
        const x = node1.nodePosition.x - node2.nodePosition.x;
        const y = node1.nodePosition.y - node2.nodePosition.y;
        dist = Math.abs(Math.sqrt(Math.pow(x, 2) + Math.pow(y, 2)));
        return dist;
      }
    }

    if (node1.hasOwnProperty('screenSize') && node2.hasOwnProperty('screenSize')) {
      let x, y;
      // if screen size is available then calculating distance based on screen size
      if(node1.screenSize.screen?.width && node1.screenSize.screen?.height) { 
        if (node1.screenSize.screen.width > node2.screenSize.screen.width) {
          x = node1.nodePagePosition.left - (node2.nodePagePosition.left * (node2.screenSize.screen.width / node1.screenSize.screen.width));
          y = node1.nodePagePosition.top - (node2.nodePagePosition.top * (node2.screenSize.screen.height / node1.screenSize.screen.height));
        } else if (node1.screenSize.screen.width < node2.screenSize.screen.width) {
          x = (node1.nodePagePosition.left * (node2.screenSize.screen.width / node1.screenSize.screen.width)) - node2.nodePagePosition.left;
          y = (node1.nodePagePosition.top * (node2.screenSize.screen.height / node1.screenSize.screen.height)) - node2.nodePagePosition.top;
        } else {
          x = node1.nodePagePosition.left - node2.nodePagePosition.left;
          y = node1.nodePagePosition.top - node2.nodePagePosition.top;
        }
      } else {
        x = node1.nodePagePosition.left - node2.nodePagePosition.left;
        y = node1.nodePagePosition.top - node2.nodePagePosition.top;
      }
      dist = Math.abs(Math.sqrt(Math.pow(x, 2) + Math.pow(y, 2)));
    } else {
      const x = node1.nodePosition.x - node2.nodePosition.x;
      const y = node1.nodePosition.y - node2.nodePosition.y;
      dist = Math.abs(Math.sqrt(Math.pow(x, 2) + Math.pow(y, 2)));
    }
  } catch (error) {
    console.error('Error calculating distance:', error);
    dist = 0; 
  }
  return dist;
};
